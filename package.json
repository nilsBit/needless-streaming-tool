{
  "name": "stream-toolkit",
  "version": "0.1.0",
  "description": "The Lab — Stream Toolkit für GameDev Streaming",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:main": "nodemon",
    "dev:renderer": "vite",
    "build": "tsc -p tsconfig.node.json && vite build && electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/tmi.js": "^1.8.6",
    "better-sqlite3": "^11.0.0",
    "express": "^4.21.0",
    "tmi.js": "^1.8.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "nodemon": "^3.1.14",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
