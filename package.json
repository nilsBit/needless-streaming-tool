{
  "name": "needless-streaming-tool",
  "version": "1.0.0",
  "description": "Needless Streaming Tool — Stream Management App",
  "author": "nilsBit",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:main": "nodemon",
    "dev:renderer": "vite",
    "build:plugin": "npm --prefix streamdeck-plugin run package",
    "build": "npm run build:plugin && tsc -p tsconfig.node.json && vite build && electron-builder",
    "build:mac": "npm run build:plugin && tsc -p tsconfig.node.json && vite build && electron-builder --mac",
    "build:win": "npm run build:plugin && tsc -p tsconfig.node.json && vite build && electron-builder --win",
    "build:all": "npm run build:plugin && tsc -p tsconfig.node.json && vite build && electron-builder --mac --win",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@coooookies/windows-smtc-monitor": "^1.0.12",
    "@types/tmi.js": "^1.8.6",
    "better-sqlite3": "^12.9.0",
    "express": "^5.2.1",
    "obs-websocket-js": "^5.0.8",
    "tmi.js": "^1.8.5",
    "ws": "^8.20.0"
  },
  "build": {
    "appId": "com.nst.streaming-tool",
    "productName": "Needless Streaming Tool",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/overlays/**/*",
      "node_modules/**/*",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/test/**"
    ],
    "extraResources": [
      {
        "from": "src/overlays",
        "to": "overlays"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "shortcutName": "Needless Streaming Tool"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/@coooookies/**"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
